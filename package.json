{
	"name": "@codeinklingon/vue-dialog",
	"version": "0.1.1",
	"type": "module",
	"private": false,
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc --noEmit --project tsconfig.app.json && vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.lib.json",

		"preview": "vite preview"
	},
	"main": "./dist/vue-dialog.cjs",
	"module": "./dist/vue-dialog.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/vue-dialog.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/vue-dialog.cjs"
			}
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CodeInKlingon/vue-dialog.git"
	},
	"bugs": {
		"url": "https://github.com/CodeInKlingon/vue-dialog/issues"
	},
	"homepage": "https://github.com/CodeInKlingon/vue-dialog#readme",
	"files": [
		"dist"
	],
	"dependencies": {
		"vue": "^3.5.13",
		"vue-component-type-helpers": "^3.3.6"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^5.2.1",
		"typescript": "~5.6.2",
		"vite": "^6.0.0",
		"vue-tsc": "^2.1.10"
	}
}
